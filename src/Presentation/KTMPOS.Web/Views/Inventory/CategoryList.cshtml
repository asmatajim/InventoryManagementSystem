@model List<KTMPOS.Common.Model.Inventory.Categories.CategoryRead>

<h1>Categories</h1>

<p>
    <a asp-action="CategoryCreate" class="btn btn-primary">Create New Category</a>
</p>

<table class="table">
    <thead>
        <tr>
            <th>S.N.</th>
            <th>Name</th>
            <th>CreatedBy</th>
            <th>CreatedDate</th>
            <th>ModifiedBy</th>
            <th>ModifiedDate</th>
            @if((await _authorizationService.AuthorizeAsync(User, Policy.InventoryEditOrDelete)).Succeeded)
            {
                <th>Actions</th>
            }
        </tr>
    </thead>
    <tbody>
        @foreach(var category in Model)
        {
            <tr>
                <td>@category.SN</td>
                <td>@category.Name</td>
                <td>@category.CreatedBy</td>
                <td>@category.CreatedDate</td>
                <td>@category.ModifiedBy</td>
                <td>@category.ModifiedDate</td>
                @if((await _authorizationService.AuthorizeAsync(User, Policy.InventoryEditOrDelete)).Succeeded)
                {
                    <td>
                        <a asp-action="CategoryUpdate" asp-route-id="@category.Id" class="btn btn-warning btn-sm">Edit</a>
                        <a href="#" data-category-id="@category.Id" class="btn btn-danger btn-sm categoryDelete">Delete</a>
                    </td>
                }
            </tr>
        }
    </tbody>
</table>
@section Scripts {
    <script src="~/js/inventory/category.js" asp-append-version="true"></script>
}

