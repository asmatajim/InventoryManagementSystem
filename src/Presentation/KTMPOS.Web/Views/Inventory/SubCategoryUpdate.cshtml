@model KTMPOS.Common.Model.Inventory.SubCategories.SubCategoryUpdate

<div class="row">
    <div class="col-md-4">
        <section>
            <form id="SubCategoryUpdate" asp-action="SubCategoryUpdate" method="post">
                <h2>Update Sub Category.</h2>
                <hr />
                <input asp-for="Id" type="hidden" class="form-control" />
                <div class="mb-3">
                    <label asp-for="CategoryId" class="control-label">Category</label>
                    <select asp-for="CategoryId" asp-items="@ViewBag.Categories" class="form-control"></select>
                    <span asp-validation-for="CategoryId" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Name" class="control-label"></label>
                    <input asp-for="Name" class="form-control" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>
                <div>
                    <button id="sub-category-submit" type="submit" class="w-100 btn btn-lg btn-primary">Save</button>
                </div>
            </form>
        </section>
    </div>
</div>