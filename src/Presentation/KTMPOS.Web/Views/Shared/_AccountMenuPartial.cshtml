<ul class="nav flex-column">
    <li class="nav-item">
        <a class="nav-link text-white" data-bs-toggle="collapse" href="#accountSubMenu" role="button" aria-expanded="false" aria-controls="accountSubMenu">
            Account
        </a>
        <div class="collapse" id="accountSubMenu">
            <ul class="nav flex-column ms-3">
                @if(User.Identity.IsAuthenticated)
                {
                    if((await _authorizationService.AuthorizeAsync(User, Policy.UserCreate)).Succeeded)
                    {
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-area="" asp-controller="Account" asp-action="Register">Register</a>
                        </li>
                    }

                    <li class="nav-item">
                        <a class="nav-link text-white" asp-area="" asp-controller="Account" asp-action="Logout">Logout</a>
                    </li>
                }
                else
                {
                    <li class="nav-item">
                        <a class="nav-link text-white" asp-area="" asp-controller="Account" asp-action="Login">Login</a>
                    </li>
                }

            </ul>
        </div>
    </li>
</ul>